# Copy this file to .env.local and adjust.

# Base URL encoded into generated QR images. On the Pi (LAN-only) this should be the
# Pi's mDNS hostname or static LAN IP, reachable from phones on the same Wi-Fi.
# Examples:
#   QR_BASE_URL=http://qrpi.local
#   QR_BASE_URL=http://192.168.1.50
QR_BASE_URL=http://localhost:3001
