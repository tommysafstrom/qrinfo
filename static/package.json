{
  "name": "qrinfo-static",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Static QR-redirect site + local admin tool",
  "scripts": {
    "build": "node --env-file-if-exists=.env admin/lib/build.mjs",
    "admin": "node --env-file-if-exists=.env admin/server.mjs",
    "serve": "node --env-file-if-exists=.env admin/lib/serve.mjs",
    "tag": "node --env-file-if-exists=.env admin/lib/tag.mjs",
    "deploy": "node --env-file-if-exists=.env admin/lib/deploy.mjs",
    "rollback": "node --env-file-if-exists=.env admin/lib/rollback.mjs"
