# Local admin tool — Cloudflare Pages settings
# Copy this file to `.env` (or `.env.local`) and fill in real values.

# CF Pages project name (the one shown in the CF dashboard).
CF_PAGES_PROJECT=qrinfo

# Optional: the preview-branch name used for the dark site (default: staging).
# CF_STAGING_BRANCH=staging

# CF API token with: Pages > Edit, Account > Read.
# Used by wrangler and by the cf-api module.
CLOUDFLARE_API_TOKEN=

# CF account ID (only required for some REST calls; wrangler can usually infer it).
CF_ACCOUNT_ID=

# Base URLs encoded into QR images at build time.
# QR_BASE_URL_PROD = the public hostname plaques should resolve to.
# QR_BASE_URL_STAGING = the dark-site hostname.
# QR_BASE_URL_LOCAL = used for local previews / thumbnails (default: http://localhost:8080).
QR_BASE_URL_PROD=https://qrinfo.example.com
QR_BASE_URL_STAGING=https://staging.qrinfo.example.com
# QR_BASE_URL_LOCAL=http://localhost:8080

# Set MOCK_WRANGLER=1 to simulate wrangler invocations without actually
# deploying. Useful for local development / testing the UI without CF credentials.
# MOCK_WRANGLER=1

# ─── Raspberry Pi deploy target ────────────────────────────────────────────
# Set DEPLOY_TARGET=pi to use the Pi-LAN deploy implementation instead of
# wrangler. Useful for dress-rehearsing the full preview/deploy/rollback flow
# on real LAN traffic before flipping CF on.
# DEPLOY_TARGET=pi

# SSH endpoint for the Pi (key must already be in ~/.ssh/authorized_keys for
# the target user; pi-deploy uses BatchMode=yes — no passwords).
# PI_SSH_HOST=claudeuser@192.168.148.4

# Remote directory layout. Defaults to /home/claudeuser/qrinfo. The deploy
# pushes code to <root>/static/ and dist artifacts to <root>/dist-{branch}/.
# PI_REMOTE_ROOT=/home/claudeuser/qrinfo

# Per-branch ports + pm2 service names (defaults shown).
# PI_PROD_PORT=8080
# PI_STAGING_PORT=8081
# PI_PROD_SERVICE=qrinfo-serve
# PI_STAGING_SERVICE=qrinfo-staging

# ─── Scan analytics (Umami) ────────────────────────────────────────────────
# Server-side, fire-and-forget event per /q/<code> hit (see runbooks/metrics.md).
# If UMAMI_HOST is unset, tracking is a no-op — the site runs exactly as before.
#
# UMAMI_HOST = base URL of your Umami instance (Pi self-host / tunnel / Cloud).
# UMAMI_WEBSITE_ID = the website UUID from Umami → Settings → Websites.
# These pass through to the Pi pm2 service automatically on deploy.
# UMAMI_HOST=http://192.168.148.4:3001
# UMAMI_WEBSITE_ID=

# QRINFO_ENV labels events by environment: local | staging | production.
# The Pi deploy sets this per branch automatically; set it for local runs.
QRINFO_ENV=local

# SERVE_TRUST_PROXY=1 — trust an inbound X-Forwarded-For for the visitor IP.
# Only enable when serve.mjs sits behind a proxy you control (e.g. nginx).
# SERVE_TRUST_PROXY=1

# UMAMI_DEBUG=1 — log events to the console instead of POSTing (testing only).
# UMAMI_DEBUG=1
